{
  // Cloudflare Worker (static assets) config for the Inksetters SPA.
  // The Vite build outputs to ./dist — this serves it with SPA routing,
  // so deep links like /about, /corporate, /admin/* all resolve to index.html.
  "name": "inksetters",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
